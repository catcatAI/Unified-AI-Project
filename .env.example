# =============================================================================
# Angela AI - Environment Configuration (Example)
# =============================================================================
# 将此文件复制为 .env 并更新为您的设置
#
# 安装步骤:
# 1. 复制此文件: cp .env.example .env
# 2. 编辑 .env 文件，更新必需的配置
# 3. 验证配置（从项目根目录运行）:
#    python -c "import sys; sys.path.insert(0, 'apps/backend'); sys.path.insert(0, 'apps/backend/src'); from core.config_validator import validate; validate()"
# =============================================================================

# -----------------------------------------------------------------------------
# 应用设置
# -----------------------------------------------------------------------------
ANGELA_ENV=development          # 运行环境: development, production, testing
NODE_ENV=development           # Node.js 运行环境
ANGELA_TESTING=true            # 启用测试模式

# -----------------------------------------------------------------------------
# 后端配置
# -----------------------------------------------------------------------------
BACKEND_HOST=127.0.0.1         # 后端服务器地址
BACKEND_PORT=8000              # 后端服务器端口 (1-65535)
BACKEND_URL=http://127.0.0.1:8000  # 后端服务器完整 URL

# -----------------------------------------------------------------------------
# 安全密钥 (生产环境必须生成真实的密钥)
# -----------------------------------------------------------------------------
# 使用以下命令生成密钥: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 或运行: python -m apps.backend.src.core.security.key_generator
#
# 示例 (请勿直接使用):
# ANGELA_KEY_A=gAAAAABl-example-key-please-generate-your-own-key-here

ANGELA_KEY_A=your_32_character_key_here_replace_before_production
ANGELA_KEY_B=your_32_character_key_here_replace_before_production
ANGELA_KEY_C=your_32_character_key_here_replace_before_production

# -----------------------------------------------------------------------------
# 数据库配置
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./angela.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# -----------------------------------------------------------------------------
# Live2D 配置
# -----------------------------------------------------------------------------
LIVE2D_MODEL_PATH=./resources/models/miara_pro_t03.model3.json
LIVE2D_SDK_CDN=https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Google Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_API_KEY=your_ollama_api_key_here

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Rovo ─────────────────────────────────────────────────────────────────────
ROVO_API_KEY=your_rovo_api_key_here

# ─── TensorFlow ───────────────────────────────────────────────────────────────
TF_USE_LEGACY_KERAS=true

# -----------------------------------------------------------------------------
# Angela Core (required)
# -----------------------------------------------------------------------------
ANGELA_HOME=./angela_home
ANGELA_LOG_LEVEL=INFO
ANGELA_CONFIG_DIR=./configs
ANGELA_DATA_DIR=./data
ANGELA_LLM_API_KEY=
ANGELA_LLM_BASE_URL=

# -----------------------------------------------------------------------------
# 开发设置
# -----------------------------------------------------------------------------
DEBUG_MODE=true
LOG_LEVEL=DEBUG