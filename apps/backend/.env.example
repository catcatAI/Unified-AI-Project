ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

AI_OPS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
MONITORING_INTERVAL=300
ANOMALY_THRESHOLD=0.1
PREDICTION_WINDOW=24
MIN_DATA_POINTS=100
AUTO_HEALING=true
PERFORMANCE_MONITORING=true

HSP_ENABLED=true
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_KEEPALIVE=60

CHROMA_HOST=localhost
CHROMA_PORT=8000
VECTOR_DIMENSION=384
MAX_MEMORY_SIZE=10000

AUTO_TRAINING=true
MODEL_PATH=./models
DATA_PATH=./data
CHECKPOINT_INTERVAL=100
BATCH_SIZE=32

# LLM Provider Keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:8000"]

# Waiting Scheduler (router.py references)
WAITING_SCHEDULER_INTERVAL=0.5
WAITING_SCHEDULER_TIMEOUT=30.0
WAITING_SCHEDULER_HEARTBEAT=5.0

# LLM Backend Override
LLAMACPP_HOST=http://127.0.0.1:8080

BACKEND_URL=http://127.0.0.1:8000
