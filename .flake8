[flake8]
# Canonical flake8 config for the whole repo.
# NOTE: flake8 7.x does NOT reliably read [tool.flake8] from pyproject.toml,
# so this dedicated .flake8 is the source of truth. It must mirror the
# [tool.flake8] block in the root pyproject.toml.
max-line-length = 100
max-complexity = 10
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    build,
    dist,
    node_modules,
    .pytest_cache,
    migrations,
    .tox,
    .mypy_cache,
    .cache,
ignore =
    E203,
    W503,
    E501,
    F401,
    E402,
    F811,
    F841,
    E226,
    E228,
    W291,
    W292,
    W293,
    W391,
    E111,
    E117,
    E122,
    E123,
    E127,
    E128,
    E221,
    E231,
    E241,
    E261,
    E265,
    E301,
    E302,
    E303,
    E305,
    E306,
    E741,
    C901,
    F405,
    F821,
    E121,
    E126,
    E131,
    E731,
    W504,
    E701,
    F601,
per-file-ignores =
    __init__.py:F401,
    test_*.py:S101,
    conftest.py:F401,
